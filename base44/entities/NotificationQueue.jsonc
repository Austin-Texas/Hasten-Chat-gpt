{
  "name": "NotificationQueue",
  "type": "object",
  "properties": {
    "notification_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "delivery_channel": {
      "type": "string",
      "enum": [
        "in_app",
        "email",
        "push",
        "sms"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "sent",
        "delivered",
        "failed"
      ],
      "default": "pending"
    },
    "retry_count": {
      "type": "number",
      "default": 0
    },
    "max_retries": {
      "type": "number",
      "default": 3
    },
    "last_attempt_at": {
      "type": "string",
      "format": "date-time"
    },
    "failure_reason": {
      "type": "string"
    },
    "delivery_provider_id": {
      "type": "string"
    },
    "scheduled_for": {
      "type": "string",
      "format": "date-time"
    },
    "quiet_hours_respected": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "notification_id",
    "user_id",
    "delivery_channel"
  ]
}