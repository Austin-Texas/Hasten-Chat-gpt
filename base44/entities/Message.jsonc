{
  "name": "Message",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string"
    },
    "load_id": {
      "type": "string"
    },
    "sender_id": {
      "type": "string"
    },
    "sender_name": {
      "type": "string"
    },
    "sender_role": {
      "type": "string"
    },
    "recipient_id": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "attachment_url": {
      "type": "string",
      "format": "uri"
    },
    "is_read": {
      "type": "boolean",
      "default": false
    },
    "message_type": {
      "type": "string",
      "enum": [
        "text",
        "status_update",
        "document",
        "alert",
        "system"
      ],
      "default": "text"
    }
  },
  "required": [
    "conversation_id",
    "sender_id",
    "content"
  ]
}